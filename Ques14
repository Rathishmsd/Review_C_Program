#include <stdio.h>

void removechar(char s[], char ch)
{
    int j = 0;

    for(int i = 0; s[i] != '\0'; i++)
    {
        if(s[i] != ch)
        {
            s[j] = s[i];
            j++;
        }
    }

    s[j] = '\0';
}

int main()
{
    char s[100], ch;

    printf("Enter string: ");
    scanf("%s", s);

    printf("Enter character to remove: ");
    scanf(" %c", &ch);

    removechar(s, ch);

    printf("Updated string: %s", s);

    return 0;
}
