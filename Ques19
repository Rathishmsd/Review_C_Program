
#include <stdio.h>

int main()
{
	int n1;
	printf("Enter the 1st array size:");
	scanf("%d",&n1);
	int n2;
	printf("Enter the 2nd array size:");
	scanf("%d",&n2);

	int a1[n1],a2[n2];
	printf("Enter the 1st array:");
	for(int i=0; i<n1; i++)
	{
		scanf("%d",&a1[i]);
	}
	printf("Enter the 2nd array:");
	for(int i=0; i<n2; i++)
	{
		scanf("%d",&a2[i]);
	}

	int c[n1+n2],k=0;
    int i=0,j=0;
	while(i<n1 && j<n2)
	{
	    if(a1[i]<a2[j])
	    {
	        c[k++]=a1[i++];
	    }
	    else
	    {
	        c[k++]=a2[j++];
	    }
	}
	while(i<n1)
	c[k++]=a1[i++];
	
	while(j<n2)
	c[k++]=a2[j++];

	for(int i=0; i<k; i++)
	{
		printf("%d",c[i]);
	}



	return 0;
}
