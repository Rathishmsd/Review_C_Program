#include <stdio.h>
#include <math.h>
int main()
{
    int n;
    scanf("%d",&n);
    
    int temp=n,count=0;
    while(temp<0)
    {
        count++;
        temp = temp/10;
    }
    temp=n;
    
    int rem,sum=0;
    while(temp<0)
    {
        rem = temp%10;
        sum = sum + pow(rem,count);
        temp=temp/10;
    }
    
    if(temp==n)
    {
        printf("It is Armstrong number!");
    }
    else
    {
        printf("It is not Armstrong number!");
    }

    return 0;
}
