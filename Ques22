#include <stdio.h>
#include <stdlib.h>

typedef struct {
	int *data;
	int size;
	int capacity;
} Vector;

void init(Vector *v)
{
	v->capacity = 2;
	v->size = 0;
	v->data = (int *)malloc(v->capacity*sizeof(int));
}

void resize(Vector *v)
{
	v->capacity = v->capacity*2;

	v->data = realloc(v->data,v->capacity*sizeof(int));
}

void push(Vector *v,int value)
{
	if(v->size == v->capacity)
	{
		resize(v);
	}

	v->data[v->size]=value;
	v->size++;
}

void pop(Vector *v)
{
	if(v->size>0)
	{
		v->size--;
	}

}

void display(Vector *v)
{
	for(int i=0; i<v->size; i++)
	{
		printf("%d ",v->data[i]);
	}
	printf("\n");
}
void freevector(Vector *v)
{
	free(v->data);
}
int main()
{
	Vector v;

	init(&v);

	push(&v,10);
	push(&v,20);

	display(&v);

	pop(&v);

	display(&v);

	freevector(&v);

	return 0;
}
