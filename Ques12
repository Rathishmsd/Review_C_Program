#include <stdio.h>
#include <math.h>
int main()
{
    int n;
    scanf("%d",&n);
    
    int sum=0;
    for(int i=1;i<n;i++)
    {
        if(n%i==0)
        {
            sum = sum +i;
        }
    }
    if(sum==n)
    {
        printf("It is Perfect number!");
    }
    else
    {
        printf("It is not Perfect number!");
    }

    return 0;
}
