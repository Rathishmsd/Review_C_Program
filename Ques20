#include <stdio.h>


int add(int a,int b)
{
    return a+b;
}
int sub(int a,int b)
{
    return a-b;
}
int mul(int a,int b)
{
    return a*b;
}
int divi(int a,int b)
{
    return a/b;
}
int main()
{
    int x,y,ch;
    
    int (*operation)(int,int);
    
    printf("Value 1:");
    scanf("%d",&x);
    printf("Value 2:");
    scanf("%d",&y);
    
    printf("1.Addition\n2.Subtraction\n3.Multiplication\n4.Division\n");
    printf("Enter the choice:");
    scanf("%d",&ch);
    
    switch(ch)
    {
        case 1:
           operation = add;
           break;
        case 2:
           operation = sub;
           break;
        case 3:
           operation = mul;
           break;
        case 4:
           operation = divi;
           break;
        default:
           printf("Invalid choice!");
           return 0;
    }
    
    int result = operation(x,y);
    
    printf("Result :%d",result);
    return 0;
}
