#include <stdio.h>


int add(int a,int b)
{
    return a+b;
}
int sub(int a,int b)
{
    return a-b;
}
int mul(int a,int b)
{
    return a*b;
}
int divi(int a,int b)
{
    return a/b;
}
int main()
{
    int x,y,ch;
    
    int (*arr[4])(int,int) = {add,sub,mul,divi};
    
    printf("Value 1:");
    scanf("%d",&x);
    printf("Value 2:");
    scanf("%d",&y);
    
    printf("1.Addition\n2.Subtraction\n3.Multiplication\n4.Division\n");
    printf("Enter the choice:");
    scanf("%d",&ch);
    
    int result;
    if(ch>=1 && ch<=4)
    {
        result = arr[ch - 1](x,y);
    }
    else
    {
        printf("Invalid choice!");
        return 0;
    }
    printf("Result :%d",result);
    return 0;
}
