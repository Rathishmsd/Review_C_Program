#include <stdio.h>

void upper(char s[])
{
   
   for(int i=0;s[i]!='\0';i++)
   {
       if(s[i]>='a' && s[i]<='z')
       {
           s[i] = s[i]- 32;
       }
   }
}
    
int main()
{
    char s[100], ch;

    printf("Enter string: ");
    scanf("%s", s);

    upper(s);

    printf("Updated string: %s", s);

    return 0;
}
