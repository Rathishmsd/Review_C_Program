
#include <stdio.h>
#include<string.h>

int strcpysafe(char str1[],char str2[],int n)
{
    int i;
    for( i=0;i<n-1 && str1[i]!='\0';i++)
    {
        str2[i]=str1[i];
    }
    str2[i]='\0';
}
int main()
{
    char str1[10];
    printf("Enter the string:");
    scanf("%s",str1);
    char str2[5];
    
    strcpysafe(str1,str2,5);
    
    printf("Copied string:%s",str2);

    return 0;
}
