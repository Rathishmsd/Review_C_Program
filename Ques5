
#include <stdio.h>

int main()
{
    char ch;
    printf("Enter the character:");
    scanf("%c",&ch);
    
    if((ch >= 'A' && ch <= 'Z')||(ch >= 'a' && ch <= 'z'))
    {
        if(ch=='A'||ch=='E'||ch=='I'||ch=='O'||ch=='U'||ch=='a'||ch=='e'||ch=='i'||ch=='o'||ch=='u')
        {
            printf("It is Vowel");
        }
        else
        {
            printf("It is consonant");
        }
    }
    else if(ch>= '0' && ch<= '9')
    {
        printf("It is digit");
    }
    else
    {
        printf("It is special symbol");
    }
    return 0;
}
